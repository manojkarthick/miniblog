  }
  .github-card .gh-title {
    @apply relative flex items-center gap-2.5 text-base font-medium text-zinc-900 dark:text-zinc-100;
  }
  .github-card .gh-title .gh-avatar {
    @apply h-8 w-8 shrink-0 rounded-full bg-zinc-200 bg-cover bg-center dark:bg-zinc-700;
  }
  .github-card .gh-title .gh-text {
    @apply min-w-0 truncate text-zinc-900 no-underline hover:underline dark:text-zinc-100;
  }
  .github-card .gh-title .gh-text:after {
    @apply absolute inset-0 content-[''];
