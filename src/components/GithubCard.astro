  }
  .github-card .gh-chips .gh-followers {
    --gh-chip-icon: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' height='16' viewBox='0 0 16 16' width='16'><path d='M2 5.5a3.5 3.5 0 1 1 5.898 2.549 5.508 5.508 0 0 1 3.034 4.084.75.75 0 1 1-1.482.235 4 4 0 0 0-7.9 0 .75.75 0 0 1-1.482-.236A5.507 5.507 0 0 1 3.102 8.05 3.493 3.493 0 0 1 2 5.5Z'/></svg>");
  }
  .github-card .gh-chips .gh-repositories {
    --gh-chip-icon: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' height='16' viewBox='0 0 16 16' width='16'><path d='M2 2.5A2.5 2.5 0 0 1 4.5 0h8.75a.75.75 0 0 1 .75.75v12.5a.75.75 0 0 1-.75.75h-2.5a.75.75 0 0 1 0-1.5h1.75v-2h-8a1 1 0 0 0-.714 1.7.75.75 0 1 1-1.072 1.05A2.495 2.495 0 0 1 2 11.5V2.5Z'/></svg>");
  }
  .github-card .gh-chips .gh-language,
  .github-card .gh-chips .gh-region {
    @apply ml-auto;
  }
  .github-card.gh-loading .gh-title .gh-avatar,
  .github-card.gh-loading .gh-description,
  .github-card.gh-loading .gh-chips span {
    @apply animate-pulse rounded-lg bg-zinc-200 text-transparent dark:bg-zinc-700;
  }
  .github-card.gh-loading .gh-chips span:before {
    @apply bg-transparent;
  }
  .github-card.gh-error {
    @apply border-red-300 bg-red-50/50 dark:border-red-900 dark:bg-red-950/20;
  }
  .github-card.gh-error .gh-description {
    @apply text-red-700 dark:text-red-300;
  }
</style>
