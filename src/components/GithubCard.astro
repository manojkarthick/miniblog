---
interface Props {
  repo?: string;
  user?: string;
}

const { repo, user } = Astro.props;

const normalize = (value: string) =>
  value
    .trim()
    .replace(/^https?:\/\/github\.com\//, "")
    .replace(/\/+$/, "");

const raw = repo ?? user ?? "";
const normalized = normalize(raw);
const parts = normalized.split("/").filter(Boolean);

const isRepo = !!repo && parts.length >= 2;
const repoName = isRepo ? `${parts[0]}/${parts[1]}` : undefined;
const username = !isRepo && parts.length >= 1 ? parts[0] : undefined;
const displayName = repoName ?? username ?? normalized;
const href = `https://github.com/${displayName}`;
---

{
  isRepo && repoName ? (
    <div class="github-card gh-loading" data-github-repo={repoName}>
      <div class="gh-title">
        <span class="gh-avatar" />
        <a class="gh-text" href={href}>
          {repoName}
        </a>
        <span class="gh-icon" />
      </div>
      <div class="gh-description">Loading repository details...</div>
      <div class="gh-chips">
        <span class="gh-stars">...</span>
        <span class="gh-forks">...</span>
        <span class="gh-license">...</span>
        <span class="gh-language">...</span>
      </div>
    </div>
  ) : username ? (
    <div class="github-card gh-simple gh-loading" data-github-user={username}>
      <div class="gh-title">
        <span class="gh-avatar" />
        <a class="gh-text" href={href}>
          {username}
        </a>
        <span class="gh-icon" />
      </div>
      <div class="gh-chips">
        <span class="gh-followers">...</span>
        <span class="gh-repositories">...</span>
        <span class="gh-region">...</span>
      </div>
    </div>
  ) : null
}

<script>
  const formatCompact = Intl.NumberFormat(undefined, {
    notation: "compact",
    maximumFractionDigits: 1,
  }).format;

  function initRepoCard(card: Element) {
    const repo = card.getAttribute("data-github-repo");
    if (!repo) return;

    fetch(`https://api.github.com/repos/${repo}`, {
      referrerPolicy: "no-referrer",
    })
      .then((res) => {
        if (!res.ok) throw new Error(`GitHub API returned ${res.status}`);
        return res.json();
      })
      .then((data) => {
        card.classList.remove("gh-loading");

        const descriptionEl = card.querySelector(".gh-description");
        if (descriptionEl) {
          if (data.description) {
            (descriptionEl as HTMLElement).textContent = String(
              data.description,
            ).replace(/:[a-zA-Z0-9_]+:/g, "");
          } else {
            (descriptionEl as HTMLElement).style.display = "none";
          }
        }

        const languageEl = card.querySelector(".gh-language");
        if (languageEl) {
          if (data.language) {
            languageEl.textContent = data.language;
          } else {
            (languageEl as HTMLElement).style.display = "none";
          }
        }

        const forksEl = card.querySelector(".gh-forks");
        if (forksEl) {
          forksEl.textContent = formatCompact(
            Number(data.forks ?? 0),
          ).replaceAll("\u202f", "");
        }

        const starsEl = card.querySelector(".gh-stars");
        if (starsEl) {
          starsEl.textContent = formatCompact(
            Number(data.stargazers_count ?? 0),
          ).replaceAll("\u202f", "");
        }

        const avatarEl = card.querySelector(".gh-avatar") as HTMLElement | null;
        if (avatarEl && data.owner?.avatar_url) {
          avatarEl.style.backgroundImage = `url(${data.owner.avatar_url})`;
        }

        const licenseEl = card.querySelector(".gh-license");
        if (licenseEl) {
          if (data.license?.spdx_id) {
            licenseEl.textContent = data.license.spdx_id;
          } else {
            (licenseEl as HTMLElement).style.display = "none";
          }
        }
      })
      .catch((error) => {
        card.classList.remove("gh-loading");
        card.classList.add("gh-error");

        const descriptionEl = card.querySelector(".gh-description");
        if (descriptionEl) {
          descriptionEl.textContent =
            "Unable to load repository details right now.";
          (descriptionEl as HTMLElement).style.display = "";
        }

        console.warn(`[GITHUB-CARD] Error loading card for ${repo}.`, error);
      });
  }

  function initUserCard(card: Element) {
    const username = card.getAttribute("data-github-user");
    if (!username) return;

    fetch(`https://api.github.com/users/${username}`, {
      referrerPolicy: "no-referrer",
    })
      .then((res) => {
        if (!res.ok) throw new Error(`GitHub API returned ${res.status}`);
        return res.json();
      })
      .then((data) => {
        card.classList.remove("gh-loading");

        const avatarEl = card.querySelector(".gh-avatar") as HTMLElement | null;
        if (avatarEl && data.avatar_url) {
          avatarEl.style.backgroundImage = `url(${data.avatar_url})`;
        }

        const followersEl = card.querySelector(".gh-followers");
        if (followersEl) {
          followersEl.textContent = formatCompact(
            Number(data.followers ?? 0),
          ).replaceAll("\u202f", "");
        }

        const repositoriesEl = card.querySelector(".gh-repositories");
        if (repositoriesEl) {
          repositoriesEl.textContent = formatCompact(
            Number(data.public_repos ?? 0),
          ).replaceAll("\u202f", "");
        }

        const regionEl = card.querySelector(".gh-region");
        if (regionEl) {
          if (data.location) {
            regionEl.textContent = data.location;
          } else {
            (regionEl as HTMLElement).style.display = "none";
          }
        }
      })
      .catch((error) => {
        card.classList.remove("gh-loading");
        card.classList.add("gh-error");
        console.warn(
          `[GITHUB-CARD] Error loading card for ${username}.`,
          error,
        );
      });
  }

  function initGithubCards() {
    document
      .querySelectorAll(".github-card.gh-loading[data-github-repo]")
      .forEach(initRepoCard);
    document
      .querySelectorAll(".github-card.gh-loading[data-github-user]")
      .forEach(initUserCard);
  }

  initGithubCards();
  document.addEventListener("astro:page-load", initGithubCards);
</script>

